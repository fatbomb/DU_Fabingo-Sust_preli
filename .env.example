# Rename this file to .env and fill in your values.
# NEVER commit .env to version control — it is gitignored.

# ─── LLM Configuration ───────────────────────────────────────────────────────
# Google Gemini API key (required for LLM enrichment)
# Get yours FREE at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default model (gemini-2.0-flash is recommended)
GEMINI_MODEL=gemini-2.0-flash

# LLM call timeout in seconds (must be well under the 30s API limit)
LLM_TIMEOUT_SECONDS=15

# ─── Supabase Configuration ───────────────────────────────────────────────────
# Used for persisting ticket analysis results and audit logs.
# Get these from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Application Configuration ───────────────────────────────────────────────
# Set to "true" to enable Supabase persistence (default: false for testing)
ENABLE_DB_PERSISTENCE=false

# Application port (default: 8000)
PORT=8000
